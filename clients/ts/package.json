{
  "name": "@baseworks/hooks",
  "version": "0.1.0",
  "description": "Webhooks capability: typed HTTP client, event catalog, projections, and CLI plugin for hooks-service (endpoint registry + signed delivery + delivery log). Contract-first, versioned with the service.",
  "type": "module",
  "publishConfig": { "access": "public" },
  "exports": {
    ".": "./dist/client.js",
    "./events": "./dist/events.js",
    "./projections": "./dist/projections.js",
    "./cli": "./dist/cli.js"
  },
  "files": ["dist", "src"],
  "scripts": { "build": "tsup", "typecheck": "tsc --noEmit", "test": "vitest run", "test:watch": "vitest" },
  "dependencies": {
    "@baseworks/cli": "^0.2.0",
    "@baseworks/foldbase": "workspace:*",
    "commander": "^15.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@baseworks/tsconfig": "workspace:*",
    "@types/node": "^22.20.0",
    "msw": "^2.14.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
